# Qlik Cloud tenant URL (no trailing slash). Example:
#   https://your-tenant.us.qlikcloud.com
QLIK_TENANT_URL=https://your-tenant.region.qlikcloud.com

# API key generated in Qlik Cloud (Profile > Settings > API keys).
# Requires read scope on apps, items, spaces, lineage-graphs.
QLIK_API_KEY=replace-me

# Optional: HTTP request timeout in seconds (default 30).
QLIK_REQUEST_TIMEOUT=30
